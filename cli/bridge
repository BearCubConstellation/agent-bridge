#!/usr/bin/env python3
"""
Agent Bridge — 命令行工具

用法:
    bridge start          # 启动 UI 服务并打开浏览器
    bridge stop           # 停止 UI 服务
    bridge restart        # 重启 UI 服务
    bridge status         # 查看运行状态
    bridge send "消息"     # 发送消息
    bridge open           # 打开浏览器
    bridge config         # 查看当前配置
    bridge version        # 查看版本
"""
import argparse
import json
import os
import platform
import subprocess
import sys
import webbrowser
from pathlib import Path

VERSION = "1.0.0"

# 项目根目录（cli/bridge 的上级）
PROJECT_ROOT = Path(__file__).resolve().parent.parent
CORE_DIR = PROJECT_ROOT / "core"
UI_DIR = PROJECT_ROOT / "ui"

# 默认路径
DEFAULT_SHARED_DIR = Path.home() / ".agent-bridge"
DEFAULT_CONFIG = DEFAULT_SHARED_DIR / "bridge.yaml"
PID_FILE = DEFAULT_SHARED_DIR / ".server.pid"
LOG_FILE = DEFAULT_SHARED_DIR / ".server.log"

# 将 core/ 加入 import 路径
sys.path.insert(0, str(CORE_DIR))


# ═══ 工具函数 ═══

def _load_config():
    """读取 bridge.yaml，返回 dict。"""
    config_path = _find_config()
    if not config_path or not config_path.exists():
        return {}
    # 先尝试 yaml
    try:
        import yaml
        with open(config_path, encoding="utf-8") as f:
            return yaml.safe_load(f) or {}
    except ImportError:
        pass
    except Exception as e:
        print(f"  Warning: YAML parse error: {e}", file=sys.stderr)
    # json fallback
    try:
        with open(config_path, encoding="utf-8") as f:
            return json.load(f)
    except Exception as e:
        print(f"  Warning: JSON parse error: {e}", file=sys.stderr)
        return {}


def _find_config():
    """按优先级查找配置文件。"""
    candidates = [
        DEFAULT_CONFIG,
        Path.home() / ".shared-chat" / "bridge.yaml",
    ]
    # 环境变量覆盖
    env_cfg = os.environ.get("BRIDGE_CONFIG")
    if env_cfg:
        candidates.insert(0, Path(env_cfg))
    for p in candidates:
        if p.exists():
            return p
    return DEFAULT_CONFIG


def _shared_dir():
    cfg = _load_config()
    d = cfg.get("shared_dir", "")
    if d:
        return Path(os.path.expanduser(d))
    return DEFAULT_SHARED_DIR


def _server_cmd():
    """构建 server 启动命令。"""
    return [
        sys.executable,
        str(UI_DIR / "server.py"),
        "--dir", str(_shared_dir()),
    ]


def _read_pid():
    if PID_FILE.exists():
        try:
            return int(PID_FILE.read_text(encoding="utf-8").strip())
        except (ValueError, OSError):
            pass
    return None


def _is_running():
    pid = _read_pid()
    if not pid:
        return False
    if platform.system() == "Windows":
        proc = subprocess.run(
            ["tasklist", "/FI", f"PID eq {pid}", "/FO", "CSV", "/NH"],
            capture_output=True,
            text=True,
            check=False,
        )
        if str(pid) in proc.stdout:
            return True
        PID_FILE.unlink(missing_ok=True)
        return False
    try:
        os.kill(pid, 0)
        return True
    except (ProcessLookupError, PermissionError):
        # PID 文件过期，清理
        PID_FILE.unlink(missing_ok=True)
        return False


def _print_ok(msg):
    print(f"  \033[32mOK\033[0m {msg}")


def _print_err(msg):
    print(f"  \033[31mERR\033[0m {msg}")


def _print_info(msg):
    print(f"  \033[36mINFO\033[0m {msg}")


# ═══ 子命令 ═══

def cmd_start(args):
    """启动 UI 服务。"""
    port = args.port or 7899
    host = args.host or "127.0.0.1"
    url = f"http://{host}:{port}"
    no_open = getattr(args, "no_open", False)
    if _is_running():
        pid = _read_pid()
        _print_info(f"服务已在运行 (PID {pid})")
        if not no_open:
            webbrowser.open(url)
        return

    shared_dir = _shared_dir()
    shared_dir.mkdir(parents=True, exist_ok=True)

    cmd = _server_cmd()
    cmd.extend(["--port", str(port)])
    if args.host:
        cmd.extend(["--host", args.host])

    log_f = open(LOG_FILE, "a", encoding="utf-8")
    popen_kwargs = {"stdout": log_f, "stderr": log_f}
    if platform.system() == "Windows":
        popen_kwargs["creationflags"] = subprocess.CREATE_NEW_PROCESS_GROUP
    else:
        popen_kwargs["start_new_session"] = True
    proc = subprocess.Popen(cmd, **popen_kwargs)
    log_f.close()  # Popen 已继承 fd，Python 侧关闭避免泄漏

    PID_FILE.parent.mkdir(parents=True, exist_ok=True)
    PID_FILE.write_text(str(proc.pid), encoding="utf-8")

    _print_ok(f"服务已启动 (PID {proc.pid})")
    _print_info(f"地址: {url}")

    if not no_open:
        import time
        time.sleep(1)
        webbrowser.open(url)


def cmd_stop(args):
    """停止 UI 服务。"""
    pid = _read_pid()
    if not pid:
        _print_info("服务未在运行")
        return

    try:
        if platform.system() == "Windows":
            # Windows: os.kill with SIGTERM doesn't work reliably
            subprocess.run(["taskkill", "/F", "/PID", str(pid)],
                           capture_output=True, check=False)
        else:
            import signal
            os.kill(pid, signal.SIGTERM)
        _print_ok(f"已发送停止信号 (PID {pid})")
    except ProcessLookupError:
        _print_info("进程已不存在")
    except PermissionError:
        _print_err("无权限停止进程，请手动 kill")
    finally:
        PID_FILE.unlink(missing_ok=True)


def cmd_restart(args):
    """重启服务。"""
    cmd_stop(args)
    cmd_start(args)


def cmd_status(args):
    """查看运行状态和配置摘要。"""
    print()
    print(f"  \033[1mAgent Bridge v{VERSION}\033[0m")
    print(f"  项目目录: {PROJECT_ROOT}")
    print(f"  配置文件: {_find_config()}")
    print()

    config = _load_config()
    shared = config.get("shared_dir", "—")
    agent_id = config.get("agent_id", "—")
    agents = config.get("agents", {})

    print(f"  共享目录: {shared}")
    print(f"  本机角色: {agent_id}")
    print()

    if agents:
        print("  Agents:")
        for aid, a in agents.items():
            name = a.get("display_name", aid)
            color = a.get("color", "—")
            wu = a.get("wakeup", {})
            url = wu.get("url", "—")
            marker = " <- 本机" if aid == agent_id else ""
            print(f"    - {name} (ID: {aid}){marker}")
            print(f"      颜色: {color}  游标: {a.get('cursor', 'line')}  来自: {a.get('filter_from', '—')}")
            print(f"      Webhook: {url}")
    print()

    # 服务状态
    if _is_running():
        pid = _read_pid()
        _print_ok(f"UI 服务运行中 (PID {pid})")
    else:
        _print_info("UI 服务未运行")

    # 文件状态
    shared_path = _shared_dir()
    active = shared_path / "active.jsonl"
    history = shared_path / "history"
    if active.exists():
        with open(active, encoding="utf-8") as f:
            count = sum(1 for line in f if line.strip())
        print(f"  当前消息: {count} 条")
    else:
        print(f"  当前消息: 无")
    if history.exists():
        archives = list(history.glob("*.jsonl"))
        print(f"  归档文件: {len(archives)} 个")
    print()


def cmd_send(args):
    """发送消息。"""
    from send import send as _send, validate_agent_id, find_active_jsonl

    config = _load_config()
    agent_id = args.agent or config.get("agent_id", "")
    shared_dir = config.get("shared_dir", "")

    if not agent_id:
        agents = config.get("agents", {})
        if len(agents) == 1:
            agent_id = next(iter(agents.keys()))
        elif len(agents) > 1:
            _print_err("配置了多个 Agent，请用 --agent 指定")
            print(f"  可选: {', '.join(agents.keys())}")
            sys.exit(1)
        else:
            _print_err("未找到 Agent 配置，请先运行 bridge start 并在 WebUI 中完成配置")
            sys.exit(1)

    if not validate_agent_id(agent_id):
        _print_err(f"无效的 Agent ID: {agent_id}")
        sys.exit(1)

    text = args.message
    if not text:
        text = sys.stdin.read().strip()
    if not text:
        _print_err("消息内容不能为空")
        sys.exit(1)

    active_file = find_active_jsonl(shared_dir)
    _send(agent_id, active_file, text, quiet=False)


def cmd_open(args):
    """打开浏览器。"""
    port = args.port or 7899
    url = f"http://127.0.0.1:{port}"
    if _is_running():
        webbrowser.open(url)
        _print_ok(f"已打开 {url}")
    else:
        _print_err("服务未运行，请先 bridge start")
        sys.exit(1)


def cmd_config(args):
    """查看当前配置。"""
    config_path = _find_config()
    if not config_path.exists():
        _print_err(f"配置文件不存在: {config_path}")
        _print_info("请先运行 bridge start，服务会自动生成默认配置")
        return

    print(f"  配置文件: {config_path}")
    print()
    try:
        print(config_path.read_text(encoding="utf-8"))
    except Exception as e:
        _print_err(f"读取失败: {e}")


def cmd_version(args):
    print(f"  Agent Bridge v{VERSION}")


def cmd_uninstall(args):
    """卸载 Agent Bridge。"""
    print()
    print("  \033[1mAgent Bridge 卸载程序\033[0m")
    print("  " + "-" * 36)
    print()

    # 1. 停止 UI 服务
    print("  1/4 停止服务...")
    if _is_running():
        cmd_stop(args)
        _print_ok("服务已停止")
    else:
        _print_info("服务未运行")
    print()

    # 2. 卸载系统服务
    print("  2/4 卸载系统定时服务...")
    uninstalled_any = False

    if sys.platform == "darwin":
        label = "com.agent-bridge.poll"
        plist_dir = Path.home() / "Library" / "LaunchAgents"
        plist_path = plist_dir / f"{label}.plist"
        if plist_path.exists():
            subprocess.run(["launchctl", "unload", str(plist_path)],
                           capture_output=True)
            plist_path.unlink()
            _print_ok(f"已卸载 launchd: {plist_path.name}")
            uninstalled_any = True

    elif sys.platform.startswith("linux"):
        service_name = "agent-bridge-poll"
        service_dir = Path.home() / ".config" / "systemd" / "user"
        for f in [f"{service_name}.service", f"{service_name}.timer"]:
            p = service_dir / f
            if p.exists():
                subprocess.run(["systemctl", "--user", "disable", f],
                               capture_output=True)
                p.unlink()
                _print_ok(f"已卸载 systemd: {f}")
                uninstalled_any = True
        if uninstalled_any:
            subprocess.run(["systemctl", "--user", "daemon-reload"],
                           capture_output=True)

    if not uninstalled_any:
        _print_info("未发现系统定时服务")
    print()

    # 3. 移除 bridge 命令
    print("  3/4 移除 bridge 命令...")
    bin_dir = Path.home() / ".local" / "bin"
    bridge_bin = bin_dir / "bridge"
    if bridge_bin.exists():
        bridge_bin.unlink()
        _print_ok(f"已删除: {bridge_bin}")
    else:
        _print_info("未找到 bridge 命令")
    print()

    # 4. 询问是否删除共享目录
    shared_dir = _shared_dir()
    shared_dir_str = str(shared_dir)
    print("  4/4 数据清理...")
    print(f"  共享目录: {shared_dir_str}")
    print(f"  源文件目录: {PROJECT_ROOT}")
    print()

    if args.force:
        remove_data = True
    else:
        try:
            reply = input("  删除所有数据（配置 + 消息 + 源码）？[y/N]: ").strip().lower()
            remove_data = reply in ("y", "yes", "是")
        except (EOFError, KeyboardInterrupt):
            remove_data = False

    if remove_data:
        cmd_stop(args)
        if shared_dir.exists():
            import shutil
            shutil.rmtree(str(shared_dir))
            _print_ok(f"已删除: {shared_dir_str}")
    else:
        print(f"  源码保留在: {PROJECT_ROOT}")
        print(f"  配置保留在: {shared_dir_str}")
        if shared_dir.exists() and (shared_dir / "active.jsonl").exists():
            print(f"  消息文件: {shared_dir / 'active.jsonl'}")
        print("  如需完整删除，手动执行:")
        print(f"    rm -rf {PROJECT_ROOT}")
        print(f"    rm -rf {shared_dir_str}")
    print()

    # 完成
    print("  " + "-" * 36)
    _print_ok("卸载完成！")
    print()
    if not remove_data:
        print("  数据已保留，可随时重新安装使用。")
        print()


# ═══ 主入口 ═══

def main():
    parser = argparse.ArgumentParser(
        prog="bridge",
        description="Agent Bridge — Agent 间异步通信中间件",
    )
    sub = parser.add_subparsers(dest="command", help="可用命令")

    parser.add_argument(
        "--version",
        action="version",
        version=f"Agent Bridge v{VERSION}",
    )

    # start
    p = sub.add_parser("start", help="启动 UI 服务并打开浏览器")
    p.add_argument("--port", "-p", type=int, help="端口 (默认 7899)")
    p.add_argument("--host", help="绑定地址 (默认 127.0.0.1)")
    p.add_argument("--no-open", action="store_true", help="启动后不自动打开浏览器")

    # stop
    p = sub.add_parser("stop", help="停止 UI 服务")

    # restart
    p = sub.add_parser("restart", help="重启 UI 服务")

    # status
    p = sub.add_parser("status", help="查看运行状态")

    # send / post
    p = sub.add_parser("send", help="发送消息")
    p.add_argument("message", nargs="?", help="消息内容（也可通过管道输入）")
    p.add_argument("--agent", "-a", help="指定发送者 Agent ID")

    p = sub.add_parser("post", help="发送消息（send 的别名）")
    p.add_argument("message", nargs="?", help="消息内容（也可通过管道输入）")
    p.add_argument("--agent", "-a", help="指定发送者 Agent ID")

    # open
    p = sub.add_parser("open", help="打开浏览器")
    p.add_argument("--port", type=int, help="端口 (默认 7899)")

    # config
    p = sub.add_parser("config", help="查看当前配置")

    # version
    p = sub.add_parser("version", help="查看版本")

    # uninstall
    p = sub.add_parser("uninstall", help="卸载 Agent Bridge")
    p.add_argument("--force", "-f", action="store_true",
                   help="跳过确认，直接卸载")

    args = parser.parse_args()

    commands = {
        "start": cmd_start,
        "stop": cmd_stop,
        "restart": cmd_restart,
        "status": cmd_status,
        "send": cmd_send,
        "post": cmd_send,
        "open": cmd_open,
        "config": cmd_config,
        "version": cmd_version,
        "uninstall": cmd_uninstall,
    }

    if args.command in commands:
        commands[args.command](args)
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
